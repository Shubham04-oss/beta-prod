{
  "info": {
    "name": "Synq Unified.to Validation",
    "description": "Postman collection to manually test and validate the internal unified.to integration routes in the Commerce module.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Push Product",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenant_id}}",
            "type": "text"
          },
          {
            "key": "X-Org-ID",
            "value": "{{org_id}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"product_id\": \"{{product_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/unified/sync/push/product",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "unified",
            "sync",
            "push",
            "product"
          ]
        }
      }
    },
    {
      "name": "2. Pull Order",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenant_id}}",
            "type": "text"
          },
          {
            "key": "X-Org-ID",
            "value": "{{org_id}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"order_id\": \"{{unified_order_id}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/unified/sync/pull/order",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "unified",
            "sync",
            "pull",
            "order"
          ]
        }
      }
    },
    {
      "name": "3. Check Sync Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/unified/sync/status/{{job_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "unified",
            "sync",
            "status",
            "{{job_id}}"
          ]
        }
      }
    },
    {
      "name": "4. Webhook (Inventory Updated)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-Tenant-ID",
            "value": "{{tenant_id}}",
            "type": "text"
          },
          {
            "key": "X-Org-ID",
            "value": "{{org_id}}",
            "type": "text"
          },
          {
            "key": "X-Signature",
            "value": "dummy-signature",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"event\": \"inventory.updated\",\n    \"data\": {\n        \"item_id\": \"item-123\",\n        \"location_id\": \"loc-456\",\n        \"available\": 50\n    }\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/unified/webhook",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "unified",
            "webhook"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "tenant_id",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "org_id",
      "value": "22222222-2222-2222-2222-222222222222"
    },
    {
      "key": "product_id",
      "value": "33333333-3333-3333-3333-333333333333"
    },
    {
      "key": "unified_order_id",
      "value": "unified-ord-123"
    },
    {
      "key": "job_id",
      "value": "job-456"
    }
  ]
}
